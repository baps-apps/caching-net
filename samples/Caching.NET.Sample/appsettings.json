{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "CacheOptions": {
    "Enabled": true,
    "Mode": "Hybrid",
    "RedisConnectionString": "localhost:6379",
    "RedisInstanceName": "sampleapp:",
    "DefaultExpiration": "00:05:00",
    "DefaultLocalExpiration": "00:02:00"
  }
}
