{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "CacheOptions": {
    "Enabled": true, // default: true
    "Mode": "Hybrid", // default: InMemory (sample override)
    "KeyPrefix": "sample-svc-v2", // REQUIRED (no default); ':' forbidden (delimiter before user key)
    "RedisConnectionString": "localhost:6379,abortConnect=false", // required when Mode=Redis/Hybrid
    "StrictRedisCertificateValidation": true, // default: true
    "FailOpen": true, // default: true
    "ThrowOnFailure": false, // default: false
    "DefaultExpiration": "00:10:00", // default: 00:10:00
    "HybridLocalCacheExpiration": "00:03:00", // optional; no fixed default (sample override)
    "TtlJitterPercentage": 0.10, // default: 0.10
    "MaximumKeyLength": 512, // default: 512
    "MaximumPayloadBytes": 1048576, // default: 1,048,576 (1 MiB)
    "EnablePayloadCompression": true, // optional; enable Brotli compression for larger payloads
    "PayloadCompressionThresholdBytes": 16384, // default: 16KiB
    "StripeLockCount": 2048, // default: 1024 (sample override)
    "StaleRefreshConcurrency": 256, // default: 256
    "FactoryTimeout": "00:00:30", // default: 00:00:30
    "RedisOperationTimeout": "00:00:02", // default: 00:00:02
    "MemorySizeLimitMb": 256 // optional; no fixed default (sample override)
  }
}
